<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>✨ 多功能粒子拼图</title>
    <style>
        /* ============================================================
           1. 全局重置 & 基础样式
           ============================================================ */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Segoe UI', 'PingFang SC', Roboto, sans-serif;
            overflow: hidden;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: background 0.8s ease;
            /* 背景由 JS 动态设置，这里留空 */
        }

        /* ============================================================
           2. 粒子画布（位于最底层）
           ============================================================ */
        #particleCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 0;
            pointer-events: none;
            opacity: 0.7;
            /* 半透明让背景透出 */
        }

        /* ============================================================
           3. 主卡片
           ============================================================ */
        #app {
            position: relative;
            z-index: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 100%;
            padding: 16px;
        }
        #game-card {
            background: rgba(0, 0, 0, 0.25);
            backdrop-filter: blur(16px) saturate(1.2);
            -webkit-backdrop-filter: blur(16px) saturate(1.2);
            border-radius: 36px;
            padding: 24px 28px 28px 28px;
            box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6), 0 0 0 1px rgba(255, 255, 255, 0.05);
            max-width: 650px;
            width: 100%;
            transition: background 0.6s ease, border-color 0.6s ease, box-shadow 0.6s ease;
            border: 1px solid rgba(255, 255, 255, 0.08);
        }

        /* ============================================================
           4. 头部
           ============================================================ */
        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            flex-wrap: wrap;
            gap: 10px;
        }
        .header-left {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .header-left h1 {
            font-size: 24px;
            font-weight: 700;
            color: #fff;
            letter-spacing: 0.5px;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .header-left h1 span {
            font-size: 26px;
        }
        .header-right {
            display: flex;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }
        .stats {
            display: flex;
            gap: 14px;
            color: rgba(255, 255, 255, 0.8);
            font-size: 14px;
            font-weight: 500;
            background: rgba(0, 0, 0, 0.3);
            padding: 4px 14px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
        }
        .stats .num {
            color: #fff;
            font-weight: 700;
            font-size: 17px;
            margin-left: 3px;
            min-width: 24px;
            display: inline-block;
            text-align: center;
        }
        .stat-item {
            display: flex;
            align-items: center;
            gap: 4px;
        }

        /* 风格按钮组 */
        .style-group {
            display: flex;
            gap: 4px;
            background: rgba(0, 0, 0, 0.2);
            padding: 4px 6px;
            border-radius: 40px;
            backdrop-filter: blur(4px);
        }
        .style-btn {
            border: none;
            background: transparent;
            color: rgba(255, 255, 255, 0.5);
            font-size: 20px;
            padding: 4px 8px;
            border-radius: 30px;
            cursor: pointer;
            transition: all 0.25s ease;
            line-height: 1;
            font-weight: 600;
        }
        .style-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.1);
        }
        .style-btn.active {
            color: #fff;
            background: rgba(255, 255, 255, 0.18);
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.15);
        }

